<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dropdown_menu"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/btnStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Προβολή Στατιστικών"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#004D40"
        android:background="@drawable/bg_ripple_standard" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20004D40" />

    <TextView
        android:id="@+id/btnPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Ανάκτηση Κωδικού"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#004D40"
        android:background="@drawable/bg_ripple_standard" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20004D40" />

    <TextView
        android:id="@+id/btnBan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Ban Φοιτητή"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:background="@drawable/bg_ripple_red" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20004D40" />

    <TextView
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Διαγραφή Φοιτητή"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#004D40"
        android:background="@drawable/bg_ripple_standard" />

</LinearLayout>