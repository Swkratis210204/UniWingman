<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            android:elevation="2dp" />

        <!-- Επικοινωνία -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Επικοινωνία"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧  support@uniwingman.gr"
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞  +30 210 123 4567"
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐  www.uniwingman.gr"
                    android:textSize="14sp"
                    android:textColor="#444444" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FAQ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Συχνές Ερωτήσεις"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <!-- FAQ 1 -->
                <TextView
                    android:id="@+id/faqQuestion1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶  Πώς προσθέτω ένα μάθημα;"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/faqAnswer1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Πήγαινε στο Προφίλ → Προσθήκη Μαθήματος. Επέλεξε φίλτρα και πάτα Αναζήτηση. Πάτα '+' στο μάθημα που θέλεις."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingStart="12dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- FAQ 2 -->
                <TextView
                    android:id="@+id/faqQuestion2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶  Πώς αλλάζω τον κωδικό μου;"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/faqAnswer2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Πήγαινε στο Προφίλ → Επεξεργασία Προφίλ. Στην ενότητα 'Αλλαγή Κωδικού' συμπλήρωσε τον παλιό και νέο κωδικό."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingStart="12dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- FAQ 3 -->
                <TextView
                    android:id="@+id/faqQuestion3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶  Πώς λειτουργεί ο AI Simulator;"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/faqAnswer3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ο AI Simulator χρησιμοποιεί τεχνητή νοημοσύνη για να απαντά σε ερωτήσεις σχετικά με το πρόγραμμα σπουδών σου βασισμένος στον οδηγό σπουδών."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingStart="12dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <!-- FAQ 4 -->
                <TextView
                    android:id="@+id/faqQuestion4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="▶  Πώς υπολογίζεται ο Μ.Ο.;"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/faqAnswer4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ο Μ.Ο. υπολογίζεται από τα περασμένα μαθήματα με βαθμό, σταθμισμένος με τις ECTS μονάδες κάθε μαθήματος."
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingStart="12dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Φόρμα Παραπόνου -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Φόρμα Παραπόνου"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Θέμα"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etComplaintSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Μήνυμα"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etComplaintMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="4"
                        android:gravity="top" />

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSubmitComplaint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Υποβολή Παραπόνου"
                    android:backgroundTint="#3D5AFE"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Replay Onboarding -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Εισαγωγικός Οδηγός"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Θέλεις να δεις ξανά τον οδηγό της εφαρμογής;"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnReplayOnboarding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Προβολή Εισαγωγικού Οδηγού"
                    android:backgroundTint="#3D5AFE"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>