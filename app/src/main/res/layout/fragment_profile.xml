<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:background="#FFFFFF">

            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_avatar_circle"
                    android:text=""
                    android:contentDescription="Avatar χρήστη" />

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_camera"
                    android:background="@drawable/bg_camera_circle"
                    android:padding="4dp"
                    android:contentDescription="Αλλαγή φωτογραφίας" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Φοιτητής"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textSize="14sp"
                android:textColor="#888888" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout android:layout_width="80dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvGpa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="22sp" android:textStyle="bold" android:textColor="#3D5AFE" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Μ.Ο." android:textSize="12sp" android:textColor="#888888" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#E0E0E0" android:layout_marginHorizontal="4dp" />

                <LinearLayout android:layout_width="80dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvStreak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#FF6D00" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Streak" android:textSize="12sp" android:textColor="#888888" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#E0E0E0" android:layout_marginHorizontal="4dp" />

                <LinearLayout android:layout_width="80dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvTotalCourses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#7C4DFF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Μαθήματα" android:textSize="12sp" android:textColor="#888888" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" android:background="#F5F6FA" />

        <!-- ΜΑΘΗΜΑΤΑ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF">

            <!-- Σε Εξέλιξη -->
            <LinearLayout android:id="@+id/rowDeclared" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Μαθήματα σε εξέλιξη">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_menu_book" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Σε Εξέλιξη" android:textSize="15sp" android:textColor="#1A1A2E" />
                <TextView android:id="@+id/badgeDeclared" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:text="0" android:textSize="12sp" android:textColor="#FFFFFF" android:background="@drawable/bg_badge_blue" android:layout_marginEnd="8dp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginStart="58dp" />

            <!-- Περασμένα -->
            <LinearLayout android:id="@+id/rowPassed" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Περασμένα Μαθήματα">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_medal" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Περασμένα Μαθήματα" android:textSize="15sp" android:textColor="#1A1A2E" />
                <TextView android:id="@+id/badgePassed" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:text="0" android:textSize="12sp" android:textColor="#FFFFFF" android:background="@drawable/bg_badge_dark" android:layout_marginEnd="8dp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginStart="58dp" />

            <!-- Κομμένα -->
            <LinearLayout android:id="@+id/rowFailed" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Κομμένα Μαθήματα">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_book_closed" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Κομμένα Μαθήματα" android:textSize="15sp" android:textColor="#1A1A2E" />
                <TextView android:id="@+id/badgeFailed" android:layout_width="26dp" android:layout_height="26dp" android:gravity="center" android:text="0" android:textSize="12sp" android:textColor="#FFFFFF" android:background="@drawable/bg_badge_blue" android:layout_marginEnd="8dp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" android:background="#F5F6FA" />

        <!-- SETTINGS -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF">

            <!-- Ρυθμίσεις -->
            <LinearLayout android:id="@+id/rowSettings" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Ρυθμίσεις">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_settings" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Ρυθμίσεις" android:textSize="15sp" android:textColor="#1A1A2E" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginStart="58dp" />

            <!-- Ειδοποιήσεις -->
            <LinearLayout android:id="@+id/rowNotifications" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Ειδοποιήσεις">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_notifications" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Ειδοποιήσεις" android:textSize="15sp" android:textColor="#1A1A2E" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginStart="58dp" />

            <!-- Επεξεργασία Προφίλ -->
            <LinearLayout android:id="@+id/rowEditProfile" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Επεξεργασία Προφίλ">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_edit" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Επεξεργασία Προφίλ" android:textSize="15sp" android:textColor="#1A1A2E" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginStart="58dp" />

            <!-- Βοήθεια -->
            <LinearLayout android:id="@+id/rowHelp" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Βοήθεια και Υποστήριξη">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_help" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Βοήθεια &amp; Υποστήριξη" android:textSize="15sp" android:textColor="#1A1A2E" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp" android:background="#F5F6FA" />

        <!-- ΑΠΟΣΥΝΔΕΣΗ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF">

            <LinearLayout android:id="@+id/rowLogout" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:focusable="true" android:clickable="true" android:background="?attr/selectableItemBackground" android:contentDescription="Αποσύνδεση">
                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_logout" android:importantForAccessibility="no" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Αποσύνδεση" android:textSize="15sp" android:textColor="#F44336" android:textStyle="bold" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_chevron_right" android:importantForAccessibility="no" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>