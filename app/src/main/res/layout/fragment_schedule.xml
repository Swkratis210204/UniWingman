<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/nav_selected"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Πρόγραμμα Εβδομάδας"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Προσθήκη"
            android:textSize="13sp"
            android:textColor="@color/nav_selected"
            android:backgroundTint="#FFFFFF"
            android:paddingHorizontal="12dp" />
    </LinearLayout>

    <!-- DAY TABS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingVertical="8dp"
        android:paddingHorizontal="8dp">

        <Button
            android:id="@+id/btnDayMon"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Δευ"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDayTue"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Τρι"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDayWed"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Τετ"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDayThu"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Πεμ"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDayFri"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Παρ"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- SCHEDULE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/scheduleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="8dp" />
    </ScrollView>

</LinearLayout>
