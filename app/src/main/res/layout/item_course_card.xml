<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardCourse"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:focusable="true"
    android:clickable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Έγχρωμη κάθετη γραμμή αριστερά (χρώμα ανάλογα με status) -->
        <View
            android:id="@+id/viewStatusBar"
            android:layout_width="4dp"
            android:layout_height="60dp"
            android:layout_marginEnd="14dp"
            android:background="#3D5AFE" />

        <!-- Κεντρικό περιεχόμενο -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Κωδικός -->
            <TextView
                android:id="@+id/tvCourseCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3155"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.05" />

            <!-- Τίτλος -->
            <TextView
                android:id="@+id/tvCourseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Στατιστική στην Πληροφορική"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- ECTS chip + Πότε το πήρε -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvEcts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 ECTS"
                    android:textSize="11sp"
                    android:textColor="#3D5AFE"
                    android:background="@drawable/bg_ects_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp" />

                <TextView
                    android:id="@+id/tvWhenTaken"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="1ο Έτος · Χειμερινό"
                    android:textSize="11sp"
                    android:textColor="#888888" />

            </LinearLayout>

            <!-- Availability -->
            <TextView
                android:id="@+id/tvAvailability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Διαθέσιμο τώρα"
                android:textSize="11sp"
                android:textColor="#888888" />

        </LinearLayout>

        <!-- Δεξί μέρος: βαθμός ή status badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvGrade"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="9.5"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_grade_circle_green" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>