<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/nav_selected"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp"
            android:text="Καλωσόρισες!"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- ΜΟ + STREAK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp">

            <!-- ΜΟ Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="#FFFFFF"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Μέσος Όρος"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp" />

                <FrameLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:gravity="center">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressGpa"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        app:indicatorColor="@color/nav_selected"
                        app:trackColor="#E8EEF7"
                        app:trackThickness="8dp"
                        app:indicatorSize="110dp"
                        android:indeterminate="false"
                        android:progress="75" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvGpa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/nav_selected" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/10"
                            android:textSize="11sp"
                            android:textColor="#888888" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Streak Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="20dp"
                android:background="#FFFFFF"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Streak"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_flame"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="@color/nav_selected" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="μέρες συνεχόμενα"
                    android:textSize="12sp"
                    android:textColor="#888888" />
            </LinearLayout>
        </LinearLayout>

        <!-- ΠΡΟΓΡΑΜΜΑ ΕΒΔΟΜΑΔΑΣ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <!-- Τίτλος + Προσθήκη -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Πρόγραμμα Εβδομάδας"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/btnAddSchedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Προσθήκη"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@color/nav_selected"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Day Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingBottom="8dp">

                <Button
                    android:id="@+id/btnDayMon"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="Δευ"
                    android:textSize="11sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnDayTue"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="Τρι"
                    android:textSize="11sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnDayWed"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="Τετ"
                    android:textSize="11sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnDayThu"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="Πεμ"
                    android:textSize="11sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnDayFri"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="Παρ"
                    android:textSize="11sp"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Schedule Slots Container -->
            <LinearLayout
                android:id="@+id/scheduleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ΕΚΚΡΕΜΕΙΣ ΕΡΓΑΣΙΕΣ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Εκκρεμείς Εργασίες"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- ΕΙΔΟΠΟΙΗΣΕΙΣ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ειδοποιήσεις"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>