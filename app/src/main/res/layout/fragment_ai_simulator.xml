<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAF9F6"
    android:importantForAccessibility="yes">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#185FA5"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="UniWingman AI"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:accessibilityHeading="true"/>

            <ImageButton
                android:id="@+id/btnClearChat"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#FFFFFF"
                android:contentDescription="Εκκαθάριση συνομιλίας"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_model_toggle"
            android:padding="3dp"
            android:importantForAccessibility="yes"
            android:contentDescription="Επιλογή μοντέλου τεχνητής νοημοσύνης">

            <Button
                android:id="@+id/btnBasicModel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Βασικό"
                android:contentDescription="Χρήση βασικού μοντέλου. Offline λειτουργία."
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_model_selected"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnThinkingModel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Σκέψη"
                android:contentDescription="Χρήση μοντέλου βαθιάς σκέψης. Online λειτουργία."
                android:textSize="13sp"
                android:textColor="#B0C8E8"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvModelDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline · Γρήγορες απαντήσεις"
            android:textColor="#B0C8E8"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:accessibilityLiveRegion="polite"
        android:scrollbars="vertical"/>

    <LinearLayout
        android:id="@+id/layoutTyping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        android:accessibilityLiveRegion="assertive">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ο UniWingman πληκτρολογεί..."
            android:textColor="#888780"
            android:textSize="12sp"
            android:textStyle="italic"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="8dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ρώτα κάτι..."
            android:contentDescription="Πεδίο εισαγωγής μηνύματος"
            android:textSize="15sp"
            android:textColor="#2C2C2A"
            android:background="@drawable/bg_input_field"
            android:padding="12dp"
            android:maxLines="4"
            android:minHeight="48dp"
            android:layout_marginEnd="8dp"
            android:inputType="textShortMessage|textAutoCorrect|textCapSentences"
            android:imeOptions="actionSend" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_send_button"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#FFFFFF"
            android:contentDescription="Αποστολή μηνύματος"
            android:padding="10dp"/>

    </LinearLayout>

</LinearLayout>