<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/white"
    android:importantForAccessibility="yes">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Δημιουργία Λογαριασμού"
        android:contentDescription="Επικεφαλίδα: Δημιουργία Λογαριασμού"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:accessibilityHeading="true" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/usernameInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="@color/nav_selected"
        app:hintTextColor="@color/nav_unselected"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/signUpUsernameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Όνομα Χρήστη (Username)"
            android:contentDescription="Εισάγετε όνομα χρήστη"
            android:textColor="@color/black"
            android:imeOptions="actionNext"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/emailInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="@color/nav_selected"
        app:hintTextColor="@color/nav_unselected"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/signUpEmailEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email"
            android:contentDescription="Εισάγετε την διεύθυνση email σας"
            android:textColor="@color/black"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        android:accessibilityLiveRegion="polite">

        <TextView
            android:id="@+id/checkLength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✗ Τουλάχιστον 8 χαρακτήρες"
            android:contentDescription="Απαίτηση: Τουλάχιστον 8 χαρακτήρες. Μη συμπληρωμένο."
            android:textColor="#F44336"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/checkUppercase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✗ Ένα κεφαλαίο γράμμα (A-Z)"
            android:contentDescription="Απαίτηση: Ένα κεφαλαίο γράμμα. Μη συμπληρωμένο."
            android:textColor="#F44336"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/checkNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✗ Έναν αριθμό (0-9)"
            android:contentDescription="Απαίτηση: Έναν αριθμό. Μη συμπληρωμένο."
            android:textColor="#F44336"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:boxStrokeColor="@color/nav_selected"
        app:hintTextColor="@color/nav_unselected"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:passwordToggleEnabled="true"
        app:passwordToggleContentDescription="Εμφάνιση ή απόκρυψη κωδικού">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/signUpPasswordEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Κωδικός"
            android:contentDescription="Εισάγετε κωδικό πρόσβασης. Ακολουθήστε τις οδηγίες ασφαλείας παραπάνω."
            android:importantForAutofill="no"
            android:imeOptions="actionNext"
            android:inputType="textPassword"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/confirmPasswordInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:boxStrokeColor="@color/nav_selected"
        app:hintTextColor="@color/nav_unselected"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:passwordToggleEnabled="true"
        app:passwordToggleContentDescription="Εμφάνιση ή απόκρυψη επιβεβαίωσης κωδικού">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/signUpConfirmPasswordEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Επιβεβαίωση κωδικού"
            android:contentDescription="Εισάγετε ξανά τον κωδικό για επιβεβαίωση"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:imeOptions="actionDone"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/registerButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cornerRadius="8dp"
        android:backgroundTint="@color/nav_selected"
        android:text="ΕΓΓΡΑΦΗ"
        android:contentDescription="Κουμπί για ολοκλήρωση εγγραφής" />

    <Button
        android:id="@+id/goToLoginButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Έχεις ήδη λογαριασμό; Σύνδεση"
        android:contentDescription="Έχετε ήδη λογαριασμό; Πατήστε εδώ για να μεταβείτε στη σελίδα σύνδεσης"
        android:textColor="@color/nav_selected"
        style="?attr/borderlessButtonStyle" />

</LinearLayout>