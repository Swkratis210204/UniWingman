<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Τίτλος" android:textStyle="bold" android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etTitle" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="π.χ. Γυμναστική"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Σχόλιο" android:textStyle="bold" android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etComment" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Προαιρετικό"
        android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Ημέρα" android:textStyle="bold" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinnerDay" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Ώρα Έναρξης" android:textStyle="bold" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinnerStart" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Ώρα Λήξης" android:textStyle="bold" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spinnerEnd" android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
